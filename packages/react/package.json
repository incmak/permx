{
  "name": "@permx/react",
  "version": "0.2.0",
  "description": "React SDK for PermX RBAC — headless components, hooks, and zero-dependency store",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "bun tsup",
    "dev": "bun tsup --watch",
    "test": "bun vitest run",
    "test:watch": "bun vitest",
    "test:coverage": "bun vitest run --coverage",
    "typecheck": "bun tsc --noEmit",
    "lint": "bun attw --pack --ignore-rules no-resolution && bun publint",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "@permx/core": ">=0.4.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@permx/core": "workspace:*",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@arethetypeswrong/cli": "^0.17.0",
    "@vitest/coverage-v8": "^3.0.0",
    "jsdom": "^26.0.0",
    "publint": "^0.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "rbac",
    "permissions",
    "access-control",
    "react",
    "react-hooks",
    "authorization",
    "permx",
    "feature-flags",
    "role-based-access-control",
    "typescript"
  ],
  "homepage": "https://github.com/Umair-N/permx#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Umair-N/permx.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/Umair-N/permx/issues"
  },
  "author": "Umair Najeeb",
  "engines": {
    "node": ">=18.0.0"
  }
}
