{
  "name": "@permx/core",
  "version": "0.2.0",
  "description": "Structured RBAC with permission keys, role inheritance, UI mappings, and feature flags",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./mongoose": {
      "import": {
        "types": "./dist/mongoose.d.ts",
        "default": "./dist/mongoose.mjs"
      },
      "require": {
        "types": "./dist/mongoose.d.cts",
        "default": "./dist/mongoose.cjs"
      }
    },
    "./express": {
      "import": {
        "types": "./dist/express.d.ts",
        "default": "./dist/express.mjs"
      },
      "require": {
        "types": "./dist/express.d.cts",
        "default": "./dist/express.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "bun tsup",
    "dev": "bun tsup --watch",
    "test": "bun vitest run",
    "test:watch": "bun vitest",
    "test:coverage": "bun vitest run --coverage",
    "typecheck": "bun tsc --noEmit",
    "lint": "bun attw --pack --ignore-rules no-resolution && bun publint",
    "run:ts": "tsx",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "mongoose": ">=7.0.0",
    "express": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "mongoose": {
      "optional": true
    },
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "mongodb-memory-server": "^10.4.0",
    "mongoose": "^8.10.0",
    "express": "^4.21.0",
    "supertest": "^7.0.0",
    "@types/express": "^5.0.0",
    "@types/supertest": "^6.0.0",
    "@arethetypeswrong/cli": "^0.17.0",
    "publint": "^0.3.0",
    "tsx": "^4.19.0"
  },
  "keywords": [
    "rbac",
    "permissions",
    "access-control",
    "authorization",
    "roles",
    "feature-flags",
    "multi-tenant",
    "mongoose",
    "express",
    "react"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
